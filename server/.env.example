# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/easy_table?schema=public"

# JWT
JWT_SECRET="change-this-to-a-random-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV="development"

# Client URL (for CORS)
CLIENT_URL="http://localhost:5173"
